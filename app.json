{
  "expo": {
    "name": "Emojis",
    "slug": "emojis",
    "version": "1.1.2",
    "orientation": "portrait",
    "scheme": "emojis",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.zack.emojis"
    },
    "plugins": [
      "expo-router",
      [
